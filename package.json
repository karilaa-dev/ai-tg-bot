{
  "name": "ai-tg-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/src/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "tsx src/db/migrate-cli.ts",
    "migrate:sandbox-data": "node dist/scripts/migrate-sandbox-data.js",
    "migrate:sandbox-data:dev": "tsx scripts/migrate-sandbox-data.ts",
    "migrate:boxlite-data": "node dist/scripts/migrate-boxlite-data.js",
    "migrate:boxlite-data:dev": "tsx scripts/migrate-boxlite-data.ts",
    "live:pi-check": "tsx scripts/live-pi-check.ts",
    "live:pi-fallback": "PI_SMOKE_FORCE_OPENROUTER=1 tsx scripts/live-pi-check.ts",
    "live:telegram-restore": "tsx scripts/live-telegram-restore.ts",
    "live:opensandbox-check": "node --import tsx scripts/live-opensandbox-check.ts",
    "live:opensandbox-turn-check": "node --import tsx scripts/live-opensandbox-turn-check.ts"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@alibaba-group/opensandbox": "0.1.10",
    "@earendil-works/pi-agent-core": "0.80.6",
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/i18n": "^1.1.2",
    "@grammyjs/runner": "^2.0.3",
    "@tavily/core": "^0.7.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-beta.22",
    "fflate": "^0.8.3",
    "grammy": "^1.43.0",
    "pg": "^8.21.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@bonkers-agency/grammy-test": "^0.1.3",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
