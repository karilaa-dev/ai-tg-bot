{
  "name": "ai-tg-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "tsx src/db/migrate-cli.ts",
    "dev:streamdump": "tsx scripts/dump-stream-parts.ts",
    "live:codex-check": "tsx scripts/live-codex-check.ts"
  },
  "engines": {
    "node": ">=22.13"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/i18n": "^1.1.2",
    "@grammyjs/runner": "^2.0.3",
    "@tavily/core": "^0.7.6",
    "ai": "^6.0.204",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-beta.22",
    "grammy": "^1.43.0",
    "js-tiktoken": "^1.0.21",
    "just-bash": "^3.0.1",
    "nanoid": "^5.1.11",
    "pg": "^8.21.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@bonkers-agency/grammy-test": "^0.1.3",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
