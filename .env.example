# Required: Telegram BotFather token used to receive updates and call Telegram APIs.
BOT_TOKEN=123456:replace-me

# Required: single Telegram admin user id allowed to create invites and bypass invite checks.
TELEGRAM_ADMIN_ID=123456789

# Required: OpenRouter API key used only for embeddings and retrieval vectors.
OPENROUTER_API_KEY=replace-me

# Required: Tavily API key used by the web_search and web_extract tools.
TAVILY_API_KEY=replace-me

# Optional runtime config

# Optional: database URL. Use sqlite:./data/bot.db for local SQLite or postgres://user:pass@host:5432/db for Postgres.
# DB_URL=sqlite:./data/bot.db

# Optional: Codex app-server model for normal chat turns.
# CODEX_MODEL=gpt-5.6-sol

# Optional: Codex app-server model for compaction summaries and compaction-time image descriptions.
# CODEX_COMPACTION_MODEL=gpt-5.6-luna

# Optional: Codex app-server image generation model used by the generate_image tool.
# CODEX_IMAGE_MODEL=gpt-image-2

# Optional: image generation quality. Use low, medium, high, or auto.
# CODEX_IMAGE_QUALITY=low

# Optional: maximum milliseconds for one generated-image app-server turn. Set 0 to disable the hard cap.
# CODEX_IMAGE_TIMEOUT_MS=300000

# Optional: Codex service tier mode. Use standard or fast.
# CODEX_SPEED_MODE=fast

# Optional: Codex model output verbosity. Use low, medium, or high.
# CODEX_VERBOSITY=high

# Optional: Codex reasoning effort for normal chat turns. Supported values depend on the selected model.
# REASONING_EFFORT=medium

# Optional: maximum milliseconds for one Codex turn. Set 0 to disable the hard cap.
# CODEX_TURN_TIMEOUT_MS=900000

# Optional: Codex reasoning summary verbosity for turn/start. Use auto, concise, detailed, or none.
# REASONING_SUMMARY=detailed

# Optional: OpenRouter embedding model for file, message, summary, and retrieval vectors.
# OPENROUTER_EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b

# Optional: fraction of usable context that triggers context-limit UX before a turn is sent.
# CONTEXT_WARN_RATIO=0.85

# Optional: Docling server base URL for DOCX conversion and low-text PDF fallback.
# DOCLING_URL=http://localhost:5001

# Optional: Docling conversion timeout in milliseconds.
# DOCLING_TIMEOUT_MS=300000

# Optional: maximum estimated file tokens to inline directly into a user message before chunking/search indexing.
# FILE_INLINE_TOKENS=6000

# Optional: root directory for per-thread persistent just-bash virtual workspaces.
# Bash curl can reach public internet URLs; localhost/private network ranges are blocked.
# BASH_WORKSPACE_ROOT=./data/bash

# Optional: maximum milliseconds for one bash tool execution.
# BASH_TIMEOUT_MS=30000

# Optional: maximum characters returned for each bash stdout/stderr stream.
# BASH_MAX_OUTPUT_CHARS=12000

# Optional: minimum milliseconds between streaming draft/status edits. Set 0 to disable throttling.
# DRAFT_UPDATE_MS=0

# Optional: delay before the /start timezone prompt is sent.
# ONBOARDING_TIMEZONE_DELAY_MS=2000

# Optional: split Codex text/reasoning stream deltas into chunks this many characters wide before draft rendering.
# STREAM_DELTA_CHARS=48

# Optional: number of newest messages preserved verbatim when compacting a thread.
# RECENT_WINDOW_MESSAGES=20

# Optional: minimum logger level. Use debug, info, warn, or error.
# LOG_LEVEL=info

# Optional Docker Compose config

# The default Docker bot service overrides DB_URL, DOCLING_URL, BASH_WORKSPACE_ROOT, and CODEX_HOME
# so runtime state lives in named Docker volumes and uses SQLite:
#   DB_URL=sqlite:/app/data/bot.db
#   DOCLING_URL=http://docling:5001
#   BASH_WORKSPACE_ROOT=/app/data/bash
#   CODEX_HOME=/home/node/.codex
#
# Volumes:
#   bot-data preserves bot.db, uploaded/generated files, and bash workspaces.
#   codex-home preserves the container's Codex login and Codex config.

# Optional: password for docker-compose.postgres.yml. Defaults to aibot when unset.
# Keep this URL-safe because the Postgres override uses it in the bot's DB_URL.
# POSTGRES_PASSWORD=aibot
