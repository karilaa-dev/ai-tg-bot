# Required: Telegram BotFather token used to receive updates and call Telegram APIs.
BOT_TOKEN=123456:replace-me

# Required: OpenRouter key used for fallback inference, image generation fallback, and embeddings.
OPENROUTER_API_KEY=replace-me

# Required: Tavily key used by web_search and web_extract.
TAVILY_API_KEY=replace-me

# Required for sandbox-backed tools. Use the same long random secret for the server's
# OPENSANDBOX_SERVER_API_KEY. Keep the lifecycle endpoint on a private Docker network.
OPEN_SANDBOX_API_KEY=replace-with-a-long-random-secret
OPEN_SANDBOX_DOMAIN=opensandbox-server:8080
OPEN_SANDBOX_PROTOCOL=http
OPEN_SANDBOX_USE_SERVER_PROXY=true

# Docker Compose/Unraid host path shared by the bot, OpenSandbox server, and runner containers.
# This must be an absolute host path, and OpenSandbox must see exactly the same string.
BOT_SHARED_HOST_PATH=/mnt/user/ai-tg-bot-shared
OPEN_SANDBOX_SHARED_HOST_ROOT=/mnt/user/ai-tg-bot-shared
OPEN_SANDBOX_NETWORK=ai-tg-bot-opensandbox

# Optional: stable deployment identity. Sandboxes from different deployments are not adopted.
# OPEN_SANDBOX_DEPLOYMENT_ID=default

# Ubuntu runner image and non-root command identity. Pin an immutable sha-* tag for production rollouts.
# OPEN_SANDBOX_IMAGE=ghcr.io/karilaa-dev/ai-agent-box:latest
# OPEN_SANDBOX_USER=agent
# OPEN_SANDBOX_GROUP=agent
# OPEN_SANDBOX_UID=1000
# OPEN_SANDBOX_GID=1000
# OPEN_SANDBOX_CPU=2
# OPEN_SANDBOX_MEMORY=512Mi

# Per-user lifecycle and control-plane timeouts in milliseconds.
# OPEN_SANDBOX_IDLE_PAUSE_MS=600000
# OPEN_SANDBOX_READY_TIMEOUT_MS=300000
# OPEN_SANDBOX_CONTROL_TIMEOUT_MS=30000
# OPEN_SANDBOX_INTERRUPT_GRACE_MS=5000

# The server Compose file can use another TOML, but its storage allowlist must still contain
# only BOT_SHARED_HOST_PATH/users, not .chat-files or .outbox.
# OPEN_SANDBOX_CONFIG_FILE=./docker/opensandbox/config.example.toml

# Optional runtime config.
# DB_URL=sqlite:./data/bot.db
# PI_CODING_AGENT_DIR=./data/pi
# MODEL_CONTEXT_TOKENS=128000
# PI_THINKING_LEVEL=medium
# PI_TURN_TIMEOUT_MS=900000
# THREAD_TITLE_TIMEOUT_MS=30000

# Optional: Codex OAuth-backed Pi models.
# CODEX_MODEL=gpt-5.6-sol
# CODEX_HELPER_MODEL=gpt-5.6-luna

# Optional: OpenRouter fallback models.
# OPENROUTER_MAIN_MODEL=openai/gpt-5.6-sol
# OPENROUTER_HELPER_MODEL=openai/gpt-5.6-luna
# OPENROUTER_IMAGE_MODEL=openai/gpt-5.4-image-2
# IMAGE_TIMEOUT_MS=300000
# OPENROUTER_EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b

# Optional external Docling server for DOCX, scanned PDFs, and PDFs without usable native text.
# DOCLING_URL=https://docling.example
# DOCLING_TIMEOUT_MS=300000

# Large-file retrieval and transient download staging.
# FILE_INLINE_TOKENS=6000
# FILE_CACHE_DIR=/tmp/ai-tg-bot-files
# FILE_CACHE_TTL_MS=3600000

# Legacy source directory retained during migration/rollback.
# BASH_WORKSPACE_ROOT=./data/bash

# Bot-side view of shared workspaces and canonical managed files. Managed files must remain
# outside AGENT_SHARED_ROOT/users so they are never mounted into a user sandbox.
# AGENT_SHARED_ROOT=./data/agent
# MANAGED_FILE_ROOT=./data/agent/.chat-files

# Maximum duration and returned output for one bash tool execution.
# BASH_TIMEOUT_MS=30000
# BASH_MAX_OUTPUT_CHARS=12000

# Telegram and logging behavior.
# DRAFT_UPDATE_MS=0
# ONBOARDING_TIMEZONE_DELAY_MS=2000
# LOG_LEVEL=info

# Container entrypoint identity. Keep this aligned with the runner UID/GID and shared-folder ownership.
# APP_UID=1000
# APP_GID=1000

# Optional PostgreSQL Compose override.
# POSTGRES_PASSWORD=aibot
