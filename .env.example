# Required: Telegram BotFather token used to receive updates and call Telegram APIs.
BOT_TOKEN=123456:replace-me

# Required: OpenRouter API key used for fallback inference, image generation fallback, and embeddings.
OPENROUTER_API_KEY=replace-me

# Required: Tavily API key used by the web_search and web_extract tools.
TAVILY_API_KEY=replace-me

# Optional runtime config

# Optional: database URL. Use sqlite:./data/bot.db for local SQLite or postgres://user:pass@host:5432/db for Postgres.
# DB_URL=sqlite:./data/bot.db

# Optional: Pi state and provider routing.
# PI_CODING_AGENT_DIR=./data/pi
# MODEL_CONTEXT_TOKENS=128000
# PI_THINKING_LEVEL=medium
# PI_TURN_TIMEOUT_MS=900000
# THREAD_TITLE_TIMEOUT_MS=30000

# Optional: Codex OAuth-backed Pi models.
# CODEX_MODEL=gpt-5.6-sol
# CODEX_HELPER_MODEL=gpt-5.6-luna

# Optional: OpenRouter fallback models.
# OPENROUTER_MAIN_MODEL=openai/gpt-5.6-sol
# OPENROUTER_HELPER_MODEL=openai/gpt-5.6-luna
# OPENROUTER_IMAGE_MODEL=openai/gpt-5.4-image-2
# IMAGE_TIMEOUT_MS=300000

# Optional: OpenRouter embedding model for chunked large-document retrieval.
# OPENROUTER_EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b

# Optional external Docling server for DOCX, scanned PDFs, and PDFs without usable native text.
# Leave unset or empty for the default single-process/single-container deployment.
# DOCLING_URL=
# DOCLING_URL=https://docling.example

# Optional: Docling conversion timeout in milliseconds.
# DOCLING_TIMEOUT_MS=300000

# Optional: maximum estimated file tokens to keep as durable extracted text before chunking/search indexing.
# FILE_INLINE_TOKENS=6000
# Optional: transient download staging/cache. Locators are hashed into opaque names; fixed TTL defaults to one hour.
# FILE_CACHE_DIR=/tmp/ai-tg-bot-files
# FILE_CACHE_TTL_MS=3600000

# Legacy source directory for pre-BoxLite thread workspaces and managed files. Keep it mounted during migration/rollback.
# BASH_WORKSPACE_ROOT=./data/bash

# BoxLite is embedded and initialized only by the first VM-backed operation. Online-only tools remain
# available if platform virtualization is unavailable. On Mac, use Apple Silicon, macOS 12+, and an
# ARM64 Node process; Hypervisor.framework is used directly, without Docker, KVM, cgroups, or root.
# Give every runtime a dedicated home; never share it concurrently with another bot process, live check,
# or external BoxLite daemon.
# BOXLITE_HOME=./data/boxlite

# VM identity includes this exact reference. Update to a new immutable sha-* tag for each production rollout;
# repointing latest alone does not replace existing persistent VMs.
# BOXLITE_AGENT_IMAGE=ghcr.io/karilaa-dev/ai-agent-box:latest
# Guest user may be a Linux username, numeric UID, or UID:GID. Named users must exist in the selected image.
# The published image uses agent (1000:1000); grant the selected UID/GID write access to the shared volume.
# BOXLITE_GUEST_USER=agent
# BOXLITE_BOX_NAME_PREFIX=ai-tg-bot

# Local shared filesystem and canonical managed-file store. BoxLite mounts each user's subtree directly
# into that user's VM; the managed-file root stays outside all user VM mounts.
# AGENT_SHARED_ROOT=./data/agent
# MANAGED_FILE_ROOT=./data/agent/.chat-files

# Per-user VM resources and lifecycle.
# BOXLITE_MEMORY_MIB=512
# BOXLITE_CPUS=2
# BOXLITE_DISK_SIZE_GB=10
# BOXLITE_IDLE_STOP_MS=600000
# Bot-side upper bound for image acquisition and VM startup; BoxLite may report its own earlier timeout.
# BOXLITE_PROVISION_TIMEOUT_MS=300000
# BOXLITE_REQUEST_TIMEOUT_MS=30000

# Maximum milliseconds for one bash tool execution and characters returned per stdout/stderr stream.
# BASH_TIMEOUT_MS=30000
# BASH_MAX_OUTPUT_CHARS=12000

# Optional: minimum milliseconds between streaming draft/status edits. Set 0 to disable throttling.
# DRAFT_UPDATE_MS=0

# Optional: delay before the /start timezone prompt is sent.
# ONBOARDING_TIMEZONE_DELAY_MS=2000


# Optional: minimum logger level. Use debug, info, warn, or error.
# LOG_LEVEL=info

# Optional Docker Compose development config. Unraid uses templates/ai-tg-bot.xml directly and does not
# need Compose. The Compose file also runs only the bot container by default; Docling remains external.

# The bot service keeps DB/Pi/legacy state in /app/data, workspaces at /data, and the embedded runtime at
# /var/lib/boxlite. It also mounts /dev/kvm and configures private writable cgroup v2.
#   DB_URL=sqlite:/app/data/bot.db
#   BASH_WORKSPACE_ROOT=/app/data/bash
#   AGENT_SHARED_ROOT=/data
#   MANAGED_FILE_ROOT=/data/.chat-files
#   BOXLITE_HOME=/var/lib/boxlite
#   PI_CODING_AGENT_DIR=/app/data/pi
#
# BOT_SHARED_HOST_PATH must be a local host path for persistent workspaces and managed chat files.
# BOT_SHARED_HOST_PATH=/absolute/path/to/boxlite-data
# APP_UID=1000
# APP_GID=1000
#
# APP_UID and APP_GID are container-entrypoint settings and are not used when running source directly on macOS.
# Keep APP_UID aligned with the guest image's workspace user (1000 for the published agent image).
# boxlite-home is a dedicated runtime volume and must not be opened concurrently by another runtime.
# codex-home is retained as a compatibility name and stores Pi sessions and OAuth credentials.

# Optional: password for docker-compose.postgres.yml. Defaults to aibot when unset.
# Keep this URL-safe because the Postgres override uses it in the bot's DB_URL.
# POSTGRES_PASSWORD=aibot
